{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js",
      "methods": ["GET", "POST", "OPTIONS"]
    },
    {
      "src": "/webhook",
      "dest": "api/index.js",
      "methods": ["POST", "OPTIONS"]
    },
    {
      "src": "/f/(.*)",
      "dest": "api/index.js",
      "methods": ["GET"]
    },
    {
      "src": "/(.*)",
      "dest": "public/index.html"
    }
  ]
}
